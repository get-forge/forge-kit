<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
      BOM-managed transitives: suppress all CVEs at the pinned version until the next platform
      dependency bump (Quarkus / etc.). Review this file when bumping quarkus.platform.version —
      not on every NVD refresh.
    -->
    <suppress>
        <notes><![CDATA[
           Quarkus 3.36.1 (all io.quarkus* modules). Revisit on quarkus.platform.version bump.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.quarkus(\.[^/]+)?/[^/]+@3\.36\.1$</packageUrl>
        <vulnerabilityName regex="true">(?s).*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           Netty 4.1.133.Final (all modules, transitive from Quarkus 3.36.1 BOM).
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/[^/]+@4\.1\.133\.Final$</packageUrl>
        <vulnerabilityName regex="true">(?s).*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           Micrometer 1.16.5 (forge-metrics via quarkus-micrometer; BOM-managed transitive).
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.micrometer/[^/]+@1\.16\.5$</packageUrl>
        <vulnerabilityName regex="true">(?s).*</vulnerabilityName>
    </suppress>
</suppressions>
