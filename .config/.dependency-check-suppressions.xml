<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Transitive Quarkus BOM dependencies — suppress by pinned version.
        packageUrl alone is NOT enough in dependency-check 12.x; pair with
        vulnerabilityName regex="true">.* to match all CVEs on that coordinate.
        Revisit when Quarkus BOM is upgraded.
    -->
    <suppress>
        <notes><![CDATA[
           io.netty:* @4.1.130.Final — transitive via Quarkus/Vert.x.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/[^/]+@4\.1\.130\.Final$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           io.vertx:* @4.5.25 — transitive via Quarkus.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.vertx/[^/]+@4\.5\.25$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           jackson-databind @2.21.2 — transitive via Quarkus REST Jackson.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.fasterxml\.jackson\.core/jackson-databind@2\.21\.2$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           micrometer-core @1.16.3 — transitive via Quarkus Micrometer.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.micrometer/micrometer-core@1\.16\.3$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           quarkus-vertx-http @3.34.1 — await Quarkus BOM upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.quarkus/quarkus-vertx-http@3\.34\.1$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>

    <!-- False positives / build tooling — specific CVE with rationale -->
    <suppress>
        <notes><![CDATA[
           plexus-utils 3.5.1 (Maven build tooling). Await plugin/BOM chain upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.codehaus\.plexus/plexus-utils@3\.5\.1$</packageUrl>
        <cve>CVE-2025-67030</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
           quarkus-hibernate-validator-spi: false positive — CVE-2023-1932 is Hibernate Validator
           core, not the Quarkus SPI jar; CPE maps artifact version to validator.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.quarkus/quarkus-hibernate-validator-spi@3\.(32|34)\.[0-9]+$</packageUrl>
        <cve>CVE-2023-1932</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
           microprofile-config-api 3.1: CVE-2022-37422, CVE-2022-45129 match cpe:payara:payara:3.1 —
           Payara server issues, not this API jar.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.microprofile\.config/microprofile-config-api@3\.1$</packageUrl>
        <cve>CVE-2022-37422</cve>
        <cve>CVE-2022-45129</cve>
    </suppress>
</suppressions>
