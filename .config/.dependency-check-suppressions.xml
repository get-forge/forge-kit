<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
      forge-kit: BOM-managed transitives at pinned Quarkus 3.36.1 versions only.
      Revisit when bumping quarkus.platform.version — add rules from the HTML report
      Suppress button if aggregate fails after a bump.
    -->
    <suppress>
        <notes><![CDATA[
           Quarkus 3.36.1 (all io.quarkus* modules). Revisit on quarkus.platform.version bump.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.quarkus(\.[^/]+)?/[^/]+@3\.36\.1$</packageUrl>
        <vulnerabilityName regex="true">(?s).*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           Netty 4.1.133.Final (transitive from Quarkus 3.36.1 BOM).
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/[^/]+@4\.1\.133\.Final$</packageUrl>
        <vulnerabilityName regex="true">(?s).*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           Jackson 2.21.4 (transitive from Quarkus 3.36.1 BOM).
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.fasterxml\.jackson(\.[^/]+)?/[^/]+@2\.21\.4$</packageUrl>
        <vulnerabilityName regex="true">(?s).*</vulnerabilityName>
    </suppress>
    <suppress>
        <notes><![CDATA[
           Micrometer 1.16.5 (transitive from Quarkus 3.36.1 BOM).
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.micrometer/[^/]+@1\.16\.5$</packageUrl>
        <vulnerabilityName regex="true">(?s).*</vulnerabilityName>
    </suppress>
</suppressions>
